    given-names: "Prasanna Kumar"
repository-code: "https://github.com/Prasanna-27eng/prompt-fuzz"
url: "https://github.com/Prasanna-27eng/prompt-fuzz"
license: MIT
version: 0.1.0
date-released: "2026-06-11"
keywords:
  - "LLM security"
  - "prompt injection"
  - "jailbreak"
  - "AI red team"
  - "guardrails"
  - "purple team"
